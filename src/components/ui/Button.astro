---
interface Props { href?: string; type?: 'button' | 'submit'; variant?: 'primary' | 'secondary'; }
const { href, type = 'button', variant = 'primary' } = Astro.props;
const className = variant === 'primary' ? 'rounded-md bg-brand-600 px-4 py-2 font-semibold text-white no-underline' : 'rounded-md border border-slate-300 px-4 py-2 font-semibold no-underline';
---
{href ? <a class={className} href={href}><slot /></a> : <button type={type} class={className}><slot /></button>}
