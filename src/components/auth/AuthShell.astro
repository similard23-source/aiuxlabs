---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---
<section class="mx-auto max-w-md rounded-xl border border-slate-200 bg-white p-6">
  <h1 class="text-2xl font-semibold">{title}</h1>
  <p class="mt-2 text-slate-600">{subtitle}</p>
  <div class="mt-6">
    <slot />
  </div>
</section>
