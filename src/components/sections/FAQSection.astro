---
interface Props {
  items: Array<{ question: string; answer: string }>;
}

const { items } = Astro.props;
---
<section>
  <h2 class="text-2xl font-semibold">FAQ</h2>
  <div class="mt-4 space-y-4">
    {items.map((item) => (
      <details class="rounded-lg border border-slate-200 bg-white p-4">
        <summary class="cursor-pointer font-medium">{item.question}</summary>
        <p class="mt-2 text-slate-700">{item.answer}</p>
      </details>
    ))}
  </div>
</section>
