---
import MainLayout from '@/layouts/MainLayout.astro';

const userEmail = Astro.locals.userEmail as string | null;
---
<MainLayout title="Dashboard | AIUXSLABS" description="Protected dashboard." canonicalPath="/dashboard" noindex={true}>
  <section class="space-y-4 rounded-lg border border-slate-200 bg-white p-6">
    <h1 class="text-2xl font-semibold">Dashboard</h1>
    <p class="text-slate-700">Ви увійшли як: <strong>{userEmail ?? 'authorized user'}</strong></p>
    <form method="post" action="/api/logout">
      <button class="rounded bg-slate-900 px-4 py-2 text-white" type="submit">Log out</button>
    </form>
  </section>
</MainLayout>
