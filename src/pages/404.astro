---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout title="Page not found | AIUXSLABS" description="Page not found." canonicalPath="/404" noindex={true}>
  <section class="rounded-lg border border-slate-200 bg-white p-8">
    <h1 class="text-3xl font-semibold">404</h1>
    <p class="mt-2 text-slate-700">The page you requested was not found.</p>
    <a href="/" class="mt-4 inline-block">Return home</a>
  </section>
</MainLayout>
