---
import MainLayout from '@/layouts/MainLayout.astro';
---
<MainLayout title="Confirm | AIUXSLABS" description="Confirm your account." canonicalPath="/confirm" noindex={true}>
  <section class="mx-auto max-w-xl rounded-lg border border-slate-200 bg-white p-6">
    <h1 class="text-2xl font-semibold">Confirm your account</h1>
    <p class="mt-2 text-slate-700">If email confirmation is enabled in Supabase, complete confirmation and then log in.</p>
    <a class="mt-4 inline-block" href="/login">Go to login</a>
  </section>
</MainLayout>
